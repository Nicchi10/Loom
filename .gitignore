
# ===== Root whitelist =====
# Everything at top-level is ignored except the entries below.
/*

!/.gitignore
!/.gitattributes
!/README.md
!/CONTRIBUTING.md
!/LICENSE
!/images
!/images/**
!/docs/
!/docs/**
!/implementations/
!/implementations/**
!/.github/
!/.github/**
!.env.example

# Local scratchpad — kept on disk, never pushed.
# The README's quickstart already shows everything a user needs.
/implementations/vb/ConsoleApp/

# ===== Build artifacts (apply at any depth) =====
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Ll]og/
[Ll]ogs/
.vs/

*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

*.tmp
*.log
*.pdb
*.ilk
*.cache
*.tlog
*.lastbuildstate
*.unsuccessfulbuild

# ===== NuGet =====
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# ===== IDE / tooling =====
_ReSharper*/
*.DotSettings.user
.idea/

[Tt]est[Rr]esult*/
*.coverage
*.coveragexml

# ===== OS =====
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# ===== Secrets / local env =====
.env
.env.*
!.env.example

# ===== Samples =====
# The samples folder is local-only; usage is illustrated in the README.
/implementations/csharp/samples/

# Local-only solution that also includes the (ignored) sample project.
# The committed Loom.sln stays clean; develop/run the sample via *.local.sln.
*.local.sln
*.local.slnx

# ===== Tests =====
# Tests are local-only; not needed by consumers of the library.
/implementations/csharp/tests/

